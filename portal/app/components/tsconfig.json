{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "#api/types/*": ["../../../api/types/*"]
    }
  },
  "include": [
    "**/*.vue",
    "**/*.ts"
  ]
}
